{
  "manifest_version": 3,
  "name": "DSA Visualizer",
  "version": "0.1.0",
  "description": "Step through your code line by line on LeetCode, HackerRank, GeeksforGeeks, and Codeforces.",
  "permissions": ["scripting", "activeTab", "storage"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://www.hackerrank.com/*",
    "https://practice.geeksforgeeks.org/*",
    "https://codeforces.com/*",
    "http://localhost:8000/*"
  ],
  "background": { "service_worker": "src/background.js", "type": "module" },
  "action": {
    "default_title": "Visualize this code",
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["src/adapters/leetcode.js"],
      "css": ["src/panel.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.hackerrank.com/challenges/*"],
      "js": ["src/adapters/hackerrank.js"],
      "css": ["src/panel.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://practice.geeksforgeeks.org/problems/*"],
      "js": ["src/adapters/gfg.js"],
      "css": ["src/panel.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://codeforces.com/problemset/problem/*"],
      "js": ["src/adapters/codeforces.js"],
      "css": ["src/panel.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/panel/index.html", "src/panel/index.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
